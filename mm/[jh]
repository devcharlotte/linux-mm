#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <unistd.h>
#include <fcntl.h>
#include <sys/mman.h>
#include <string.h>
#include <errno.h>
#include <sys/prctl.h>
#include <sys/time.h>
#include <time.h>

#define GB(x) ((size_t)(x) << 30)
#define CHUNK (6410241024)
#define PATTERN 0x42

//--------------------------------------------------
// sysfs read
//--------------------------------------------------
long read_sys(const char *p) {
long v = 0;
FILE *f = fopen(p, "r");
if(!f) return -1;
fscanf(f, "%ld", &v);
fclose(f);
return v;
}

//--------------------------------------------------
// sysfs write number
//--------------------------------------------------
int write_sys_num(const char *p, long v) {
FILE *f = fopen(p, "w");
if(!f) { perror("write_sys_num"); return -1; }
fprintf(f, "%ld", v);
fclose(f);
return 0;
}

//--------------------------------------------------
// sysfs write string
//--------------------------------------------------
int write_sys_str(const char *p, const char *s) {
FILE *f = fopen(p, "w");
if(!f) { perror("write_sys_str"); return -1; }
fprintf(f, "%s", s);
fclose(f);
return 0;
}

//--------------------------------------------------
// reset KSM
//--------------------------------------------------
void reset_ksm() {
printf("[KSM] Resetting...\n");

write_sys_num("/sys/kernel/mm/ksm/run", 0);
write_sys_str("/sys/kernel/mm/ksm/smart_scan", "0");
write_sys_str("/sys/kernel/mm/ksm/advisor_mode", "none");

write_sys_num("/sys/kernel/mm/ksm/pages_to_scan", 100);
write_sys_num("/sys/kernel/mm/ksm/sleep_millisecs", 100);

sleep(1);


}

//--------------------------------------------------
// cpu measure helper
//--------------------------------------------------
double cpu_now() {
unsigned long long a,b,c,d;
FILE *f = fopen("/proc/stat","r");
if(!f) return -1;
fscanf(f, "cpu %llu %llu %llu %llu", &a,&b,&c,&d);
fclose(f);
return (double)(a+b+c+d);
}

//--------------------------------------------------
// main
//--------------------------------------------------
int main(int argc, char **argv) {

int mode_prctl = 0;
int smart = 0;
char advisor[32] = "none";

//--------------------------------------------------
// parse args
//--------------------------------------------------
for(int i=1;i<argc;i++){
    if(strstr(argv[i], "merge=prctl")) mode_prctl = 1;
    if(strstr(argv[i], "merge=madv" )) mode_prctl = 0;

    if(strstr(argv[i], "smart=on" )) smart = 1;
    if(strstr(argv[i], "smart=off")) smart = 0;

    if(strstr(argv[i], "advisor=scan")) strcpy(advisor, "scan-time");
    if(strstr(argv[i], "advisor=none")) strcpy(advisor, "none");
}

printf("[CONFIG] merge=%s\n", mode_prctl ? "prctl" : "madv");
printf("[CONFIG] smart=%s\n", smart ? "ON" : "OFF");
printf("[CONFIG] advisor=%s\n", advisor);

//--------------------------------------------------
// reset KSM
//--------------------------------------------------
reset_ksm();

//--------------------------------------------------
// KSM tunables
//--------------------------------------------------
write_sys_str("/sys/kernel/mm/ksm/smart_scan", smart ? "1" : "0");
write_sys_str("/sys/kernel/mm/ksm/advisor_mode", advisor);
write_sys_num("/sys/kernel/mm/ksm/pages_to_scan", 20000);
write_sys_num("/sys/kernel/mm/ksm/sleep_millisecs", 20);

//--------------------------------------------------
// allocate memory
//--------------------------------------------------
size_t total_gb = 5;
size_t bytes = GB(total_gb);
size_t chunks = bytes / CHUNK;

printf("[INFO] Allocating %zu chunks (%zu MB each) = %zu GB\n",
       chunks, CHUNK>>20, total_gb);

void **ptr = malloc(sizeof(void*) * chunks);

for(size_t i=0;i<chunks;i++){
    ptr[i] = mmap(NULL, CHUNK,
                   PROT_READ | PROT_WRITE,
                   MAP_PRIVATE | MAP_ANONYMOUS,
                   -1, 0);

    if(ptr[i] == MAP_FAILED){
        perror("mmap");
        exit(1);
    }

    if(mode_prctl){
        prctl(PR_SET_MEMORY_MERGE, 1, 0,0,0);
    } else {
        if(madvise(ptr[i], CHUNK, MADV_MERGEABLE)){
            perror("madvise");
            exit(1);
        }
    }
}

sleep(1);

//--------------------------------------------------
// fill pattern
//--------------------------------------------------
printf("[INFO] Filling memory...\n");
for(size_t i=0;i<chunks;i++)
    memset(ptr[i], PATTERN, CHUNK);

for(size_t i=0;i<chunks;i++)
    mlock(ptr[i], CHUNK);

//--------------------------------------------------
// start KSM
//--------------------------------------------------
printf("[INFO] Starting KSM...\n");
write_sys_num("/sys/kernel/mm/ksm/run", 1);

//--------------------------------------------------
// header
//--------------------------------------------------
printf("\n%-6s %-10s %-10s %-10s %-10s %-10s %-10s %-10s\n",
       "sec","shared","sharing","unshared","volatile",
       "scans","profit","cpu%");

long last_shared=-1, stable=0;

double prev_cpu = cpu_now();
double prev_time = (double)clock()/CLOCKS_PER_SEC;

//--------------------------------------------------
// loop
//--------------------------------------------------
for(long s=1;;s++){
    
    long shared   = read_sys("/sys/kernel/mm/ksm/pages_shared");
    long sharing  = read_sys("/sys/kernel/mm/ksm/pages_sharing");
    long unshared = read_sys("/sys/kernel/mm/ksm/pages_unshared");
    long vol      = read_sys("/sys/kernel/mm/ksm/pages_volatile");
    long scans    = read_sys("/sys/kernel/mm/ksm/full_scans");
    long profit   = read_sys("/sys/kernel/mm/ksm/general_profit");

    double now_cpu = cpu_now();
    double now_t = (double)clock()/CLOCKS_PER_SEC;

    double cpu_usage = -1.0;
    if(prev_cpu > 0){
        cpu_usage = ((now_cpu - prev_cpu) / ((now_t - prev_time)*100.0));
    }

    prev_cpu = now_cpu;
    prev_time = now_t;

    printf("%-6ld %-10ld %-10ld %-10ld %-10ld %-10ld %-10ld %-10.2f\n",
           s, shared, sharing, unshared, vol, scans, profit, cpu_usage);

    if(shared == last_shared) stable++;
    else stable = 0;

    last_shared = shared;

    if(stable > 10 && scans > 0){
        printf("[INFO] Converged.\n");
        break;
    }

    sleep(1);
}

//--------------------------------------------------
// cleanup
//--------------------------------------------------
for(size_t i=0;i<chunks;i++)
    munmap(ptr[i], CHUNK);

free(ptr);
printf("[INFO] Finished.\n");
return 0;


}
